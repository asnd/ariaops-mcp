# ─── AriaOps MCP Server ────────────────────────────────────────────────────────
ARIAOPS_HOST=vrops.example.com
ARIAOPS_USERNAME=admin
ARIAOPS_PASSWORD=changeme
ARIAOPS_AUTH_SOURCE=local
ARIAOPS_VERIFY_SSL=true
ARIAOPS_TRANSPORT=stdio
ARIAOPS_PORT=8080
ARIAOPS_LOG_LEVEL=INFO
# Uncomment to enable write/mutating operations (disabled by default)
# ARIAOPS_ENABLE_WRITE_OPERATIONS=false

# ─── Agent Skills ─────────────────────────────────────────────────────────────
# Path to directory containing SKILL.md files. Leave empty to disable skills.
# ARIAOPS_SKILLS_DIR=/path/to/skills

# ─── Test-UI: LLM Gateway ─────────────────────────────────────────────────────
# OpenAI-compatible LLM gateway URL (e.g. LiteLLM proxy)
LITELLM_BASE_URL=https://litellm.example.com
# JWT token for authenticating to the gateway (obtain via Azure SSO or paste manually)
LITELLM_TOKEN=

# ─── Test-UI: Azure AD SSO (optional overrides) ───────────────────────────────
# Required only if you want to use the "Get Token via Azure SSO" button
# AZURE_TENANT_ID=your-azure-tenant-id
# AZURE_CLIENT_ID=your-azure-client-id
