# ─── AriaOps MCP Server ────────────────────────────────────────────────────────
# Legacy single-instance configuration (used when instances.yaml is absent)
ARIAOPS_HOST=vrops.example.com
ARIAOPS_USERNAME=admin
ARIAOPS_PASSWORD=changeme
ARIAOPS_AUTH_SOURCE=local
ARIAOPS_VERIFY_SSL=true
ARIAOPS_TRANSPORT=stdio
ARIAOPS_PORT=8080

# ─── Multi-Instance Configuration ─────────────────────────────────────────────
# Path to instances.yaml (default: ./instances.yaml next to .env)
# ARIAOPS_INSTANCES_FILE=./instances.yaml
# Default instance when no explicit instance is specified
# ARIAOPS_DEFAULT_INSTANCE=prod

# Per-instance credentials (format: ARIAOPS_{INSTANCE_UPPER}_USERNAME/_PASSWORD)
# Falls back to ARIAOPS_USERNAME/PASSWORD if instance-specific vars are not set.
# ARIAOPS_PROD_USERNAME=svc-mcp-prod
# ARIAOPS_PROD_PASSWORD=...
# ARIAOPS_PROD_FI_USERNAME=svc-mcp-fi
# ARIAOPS_PROD_FI_PASSWORD=...
# ARIAOPS_TESTBED_USERNAME=lab-user
# ARIAOPS_TESTBED_PASSWORD=...

# Per-instance host override (overrides instances.yaml value)
# ARIAOPS_PROD_HOST=vrops-prod-override.example.com

# ─── OAuth 2.x (HTTP transport only) ──────────────────────────────────────────
# When enabled, /health stays open but the MCP endpoint requires a valid JWT
# in the Authorization: Bearer <token> header.
# ARIAOPS_HTTP_OAUTH_ENABLED=false
# ARIAOPS_HTTP_OAUTH_ISSUER_URL=https://issuer.example.com
# ARIAOPS_HTTP_OAUTH_RESOURCE_SERVER_URL=https://mcp.example.com
#
# Instance-level scope enforcement (format: ariaops:{instance}:{access})
# Examples:
#   ariaops:prod:read     → read access to 'prod' instance
#   ariaops:testbed:write → write access to 'testbed'
#   ariaops:*:read        → read access to all instances (infra-ops)
#   ariaops:*:write       → full access to all instances
#
# Verification material — set EITHER JWT_KEY or JWKS_URL, not both:
# ARIAOPS_HTTP_OAUTH_JWT_KEY=replace-me-with-a-32-byte-random-secret
# ARIAOPS_HTTP_OAUTH_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
# ARIAOPS_HTTP_OAUTH_JWT_ALGORITHMS=HS256
# ARIAOPS_HTTP_OAUTH_AUDIENCE=https://mcp.example.com
# ARIAOPS_HTTP_OAUTH_REQUIRED_SCOPES=mcp:read
# ARIAOPS_HTTP_OAUTH_LEEWAY_SECONDS=30
# ARIAOPS_HTTP_OAUTH_JWKS_CACHE_TTL=300

ARIAOPS_LOG_LEVEL=INFO
# Uncomment to enable write/mutating operations globally (deprecated in multi-instance mode)
# ARIAOPS_ENABLE_WRITE_OPERATIONS=false

# ─── Agent Skills ─────────────────────────────────────────────────────────────
# Path to directory containing SKILL.md files. Leave empty to disable skills.
# ARIAOPS_SKILLS_DIR=/path/to/skills

# ─── Test-UI: LLM Gateway ─────────────────────────────────────────────────────
# OpenAI-compatible LLM gateway URL (e.g. LiteLLM proxy)
LITELLM_BASE_URL=https://litellm.example.com
# JWT token for authenticating to the gateway (obtain via Azure SSO or paste manually)
LITELLM_TOKEN=

# ─── Test-UI: Azure AD SSO (optional overrides) ───────────────────────────────
# Required only if you want to use the "Get Token via Azure SSO" button
# AZURE_TENANT_ID=your-azure-tenant-id
# AZURE_CLIENT_ID=your-azure-client-id
